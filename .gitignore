# Rust build artifacts
**/target
**/Cargo.lock.bak

# Lake build cache
**/.lake

# Scratch / OS
/tmp
.DS_Store

# Local-dev convenience symlink (see CLAUDE.md). Points outside the repo;
# do not commit.
.claude/

# Git worktrees for isolated agent work.
.worktrees/

docs/site/*.png

.playwright-mcp

# Build artifacts produced by `nix run .#populate` (sail-lean tree
# + pilout). Reproducible from the flake — never commit.
/build/

# Auto-generated Lean extraction files. These are produced by
# `nix run .#populate` from the pilout — the local build IS the
# source of truth. Two .lean files in this directory are NOT
# regenerated and stay tracked:
#   - ArithTable.lean    (hand-transcribed from arith_table_data.rs)
#   - MemoryBuses.lean   (hand-curated subset of memory-bus emissions)
ZiskFv/Extraction/*.lean
!ZiskFv/Extraction/ArithTable.lean
!ZiskFv/Extraction/MemoryBuses.lean
!ZiskFv/Extraction/OperationBuses.lean

# Nix flake build outputs (symlinks)
/result
/result-*

# Cachix auth tokens (write-scoped, must never be committed)
/.zisk-rw-token
/.cachix-token
/*.cachix-token

# Legacy leftover from the deleted docker pipeline (root-owned, harmless)
/out/
