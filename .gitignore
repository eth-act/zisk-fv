/.zisk-rw-token
/.cachix-token
/*.cachix-token

# Legacy leftover from the deleted docker pipeline (root-owned, harmless)
/out/

.rgignore

# Per-worktree AI status trail — local-only, never committed (see #162 fdd5b4ef, #159 review P2)
