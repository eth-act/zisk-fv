def AddCompleteness (iface : Rv.Interface) : Prop :=
  ∀ raw, SailAddExecutableRaw raw → Rv.Interface.ziskCircuitCovered iface raw

theorem add_completeness_of_shape_circuit_covered_known_good
    (iface : Rv.Interface)
