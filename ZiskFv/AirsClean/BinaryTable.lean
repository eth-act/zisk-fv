    (h : binaryTable.Spec t)
    (h_op : t.op.val = OP_ADD ∨ t.op.val = OP_SUB)
    (h_pos : t.pos_ind.val = 1) :
    t.flags.val = 8 * signByte t.c_byte.val := by
